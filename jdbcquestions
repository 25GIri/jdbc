import java.sql.*;

public class Ques5
{
    public static void main(String args[])
    {
        try
        {
            Class.forName("com.microsoft.sqlserver.jdbc.SQLServerDriver");

            Connection con = DriverManager.getConnection(
                "jdbc:sqlserver://localhost:1433;databaseName=Productdb;encrypt=true;trustServerCertificate=true",
                "sa",
                "StrongPass@123");

            con.setAutoCommit(false);

            try
            {
                PreparedStatement ps1 =
                    con.prepareStatement(
                        "INSERT INTO Sales VALUES(?,?,?,GETDATE())");

                ps1.setInt(1, 4);
                ps1.setInt(2, 101);
                ps1.setInt(3, 1);

                ps1.executeUpdate();

                PreparedStatement ps2 =
                    con.prepareStatement(
                        "INSERT INTO Sales VALUES(?,?,?,GETDATE())");

                ps2.setInt(1, 5);
                ps2.setInt(2, 102);
                ps2.setInt(3, 1);

                ps2.executeUpdate();

                con.commit();

                System.out.println(
                    "Transaction Successful - Commit Done");
            }
            catch(Exception e)
            {
                con.rollback();

                System.out.println(
                    "Transaction Failed - Rollback Done");
            }

            con.close();
        }
        catch(Exception e)
        {
            e.printStackTrace();
        }
    }
}
