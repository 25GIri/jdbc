import java.sql.*;

public class Productdb
{
    public static void main(String args[])
    {
        try
        {
            Class.forName("com.microsoft.sqlserver.jdbc.SQLServerDriver");

            Connection con = DriverManager.getConnection(
                "jdbc:sqlserver://localhost:1433;databaseName=Productdb;encrypt=true;trustServerCertificate=true",
                "sa",
                "StrongPass@123");

            Statement st = con.createStatement();

            // Category Table
            st.executeUpdate(
                "CREATE TABLE Category(" +
                "CatId INT PRIMARY KEY," +
                "CatDesc VARCHAR(50))");

            // Product Table
            st.executeUpdate(
                "CREATE TABLE Product(" +
                "ProdId INT PRIMARY KEY," +
                "ProdName VARCHAR(50)," +
                "Price DECIMAL(10,2)," +
                "CatId INT," +
                "FOREIGN KEY(CatId) REFERENCES Category(CatId))");

            // Sales Table
            st.executeUpdate(
                "CREATE TABLE Sales(" +
                "SaleId INT PRIMARY KEY," +
                "ProdId INT," +
                "Qty INT," +
                "SaleDate DATE," +
                "FOREIGN KEY(ProdId) REFERENCES Product(ProdId))");

            System.out.println("Tables Created Successfully");

            // Insert into Category
            st.executeUpdate(
                "INSERT INTO Category VALUES(1,'Electronics')");

            st.executeUpdate(
                "INSERT INTO Category VALUES(2,'Books')");

            st.executeUpdate(
                "INSERT INTO Category VALUES(3,'Clothing')");

            // Insert into Product
            st.executeUpdate(
                "INSERT INTO Product VALUES(101,'Laptop',50000,1)");

            st.executeUpdate(
                "INSERT INTO Product VALUES(102,'Mobile',25000,1)");

            st.executeUpdate(
                "INSERT INTO Product VALUES(103,'Java Book',500,2)");

            // Insert into Sales
            st.executeUpdate(
                "INSERT INTO Sales VALUES(1,101,2,'2026-06-01')");

            st.executeUpdate(
                "INSERT INTO Sales VALUES(2,102,1,'2026-06-02')");

            System.out.println("Records Inserted Successfully");

            st.close();
            con.close();
        }
        catch(Exception e)
        {
            e.printStackTrace();
        }
    }
}

