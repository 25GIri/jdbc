import java.sql.*;

public class Ques2
{
    public static void main(String args[])
    {
        try
        {
            Class.forName("com.microsoft.sqlserver.jdbc.SQLServerDriver");

            Connection con = DriverManager.getConnection(
                "jdbc:sqlserver://localhost:1433;databaseName=ProductDB;encrypt=true;trustServerCertificate=true",
                "sa",
                "StrongPass@123");

            PreparedStatement ps = con.prepareStatement(
                "SELECT C.CatDesc, AVG(P.Price) AS AvgPrice " +
                "FROM Category C " +
                "JOIN Product P ON C.CatId = P.CatId " +
                "GROUP BY C.CatDesc");

            ResultSet rs = ps.executeQuery();

            System.out.println("Category\tAverage Price");
            System.out.println("---------------------------");

            while(rs.next())
            {
                String category = rs.getString("CatDesc");
                double avgPrice = rs.getDouble("AvgPrice");

                System.out.println(category + "\t" + avgPrice);
            }

            rs.close();
            ps.close();
            con.close();
        }
        catch(Exception e)
        {
            e.printStackTrace();
        }
    }
}

